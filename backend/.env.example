# Server
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed browser origins
CORS_ORIGINS=http://localhost:3000

# Database (docker-compose exposes Postgres on 5433)
DATABASE_URL=postgresql://inkwell:inkwell@localhost:5434/inkwell

# Auth
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# OAuth (leave empty to disable a provider)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:4000/api/v1/auth/oauth

# Frontend URL for post-OAuth redirect and reset-password links
FRONTEND_URL=http://localhost:3000

# AES-256-GCM key (32 bytes, base64) for encrypting Medium tokens
TOKEN_ENCRYPTION_KEY=
